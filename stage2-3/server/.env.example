# ─── Server ───────────────────────────────────────────────────
PORT="4000"
# Comma-separated list of allowed browser origins (Stage 3 web app).
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4173"
MAX_BLOB_BYTES="524288000"        # 500 MB max per file
MAX_VAULT_BYTES="16106127360"     # 15 GB max per vault

# ─── Blob storage: Backblaze B2 (primary) ─────────────────────
# When ALL FOUR of these are set, encrypted blob bodies are stored in B2
# (S3-compatible) instead of on local disk. Leave any of them unset to fall
# back to local disk under data/blobs/ — handy for development, NOT
# recommended for production (survives only as long as this one disk does).
#
# Find these in the Backblaze B2 console: create an "S3 compatible" Application
# Key scoped to just this bucket if possible.
B2_ENDPOINT=""           # e.g. https://s3.us-west-004.backblazeb2.com
B2_REGION="us-west-004"  # the region segment from your endpoint
B2_ACCESS_KEY_ID=""      # B2 "keyID"
B2_SECRET_ACCESS_KEY=""  # B2 "applicationKey"
B2_BUCKET="nekobox-vault"

# ─── Backups (see BACKUP.md) ───────────────────────────────────
# Local snapshot folder (used when BACKUP_S3_BUCKET below is not set).
BACKUP_DIR=""            # default: ./backups
BACKUP_RETENTION="7"     # how many snapshots to keep

# Optional: sync each snapshot to a second S3-compatible bucket instead of a
# local folder. If only BACKUP_S3_BUCKET is set, the B2_* credentials/endpoint
# above are reused (i.e. "a second bucket in the same B2 account"). Set the
# BACKUP_S3_* overrides below for a genuinely different account or provider.
BACKUP_S3_BUCKET=""              # e.g. nekobox-vault-backup
BACKUP_S3_PREFIX="nekobox-backups"
# BACKUP_S3_ENDPOINT=""
# BACKUP_S3_REGION=""
# BACKUP_S3_ACCESS_KEY_ID=""
# BACKUP_S3_SECRET_ACCESS_KEY=""

# Only needed if you point DATA_DIR somewhere other than ./data.
DATA_DIR=""
