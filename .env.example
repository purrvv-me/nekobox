# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nekobox?schema=public"

# ─── Auth ────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-string"
# Session lifetime in seconds (default 7 days).
JWT_TTL_SECONDS="604800"

# ─── File storage: Backblaze B2 (S3-compatible, checked FIRST) ─────────
# Find these in the Backblaze B2 console: create an "S3 compatible"
# Application Key, ideally scoped to just this bucket.
B2_ENDPOINT=""           # e.g. https://s3.us-west-004.backblazeb2.com
B2_REGION="us-west-004"  # the region segment from your endpoint
B2_ACCESS_KEY_ID=""      # B2 "keyID"
B2_SECRET_ACCESS_KEY=""  # B2 "applicationKey"
B2_BUCKET="nekobox-vault"

# ─── File storage: Cloudflare R2 (S3-compatible, checked if B2 unset) ──
# From the R2 dashboard → Manage R2 API Tokens.
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="nekobox-vault"
# Endpoint is derived from the account id but can be overridden:
# R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# If NEITHER B2_* nor R2_* above are fully set, files are stored on local disk
# under .storage/ — fine for local development, NOT viable on serverless
# hosts (Netlify/Vercel) since there's no persistent disk between requests.

# Max upload size in bytes (default 100 MB). Used for presign + rate context.
MAX_UPLOAD_BYTES="104857600"

# ─── Email recovery (optional) ───────────────────────────────
# Master switch for the whole feature (UI + API routes). Defaults to disabled;
# set to "true" only after real email delivery is configured and you accept the
# zero-knowledge trade-off. Existing users can still UNLINK their email while
# this is off (DELETE /api/auth/email-recovery/bind is never gated).
ENABLE_EMAIL_RECOVERY="false"

# Set RESEND_API_KEY to enable real email delivery via Resend. Without it, the
# mailer logs to the server console only in dev/test and fails closed in prod.
#
# Sandbox testing (no verified domain yet): Resend lets an unverified account
# send FROM the shared "onboarding@resend.dev" address (the default below) TO
# the email you signed up to Resend with — no code changes needed for that.
# Sending to arbitrary recipients requires a verified sending domain; once
# verified, just change MAIL_FROM to an address on your domain.
#
# Production key scope: create the key with Resend's "Sending access" (not
# "Full access") permission — if it leaks, the blast radius is limited to
# sending mail, not full control of your Resend account.
RESEND_API_KEY=""
MAIL_FROM="NekoBox <onboarding@resend.dev>"
# Separate key for hashing recovery emails (defaults to a JWT_SECRET derivation):
EMAIL_HASH_KEY=""
# Base URL used to build recovery links in emails:
APP_URL="http://localhost:3000"
