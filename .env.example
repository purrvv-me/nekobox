# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nekobox?schema=public"

# ─── Auth ────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="change-me-to-a-long-random-string"
# Session lifetime in seconds (default 7 days).
JWT_TTL_SECONDS="604800"

# ─── Cloudflare R2 (S3-compatible) ───────────────────────────
# From the R2 dashboard → Manage R2 API Tokens.
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="nekobox-vault"
# Endpoint is derived from the account id but can be overridden:
# R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# Max upload size in bytes (default 100 MB). Used for presign + rate context.
MAX_UPLOAD_BYTES="104857600"

# ─── Email recovery (optional) ───────────────────────────────
# Set RESEND_API_KEY to enable real email delivery via Resend; otherwise the
# mailer logs the recovery link to the server console (dev mode).
RESEND_API_KEY=""
MAIL_FROM="NekoBox <onboarding@resend.dev>"
# Separate key for hashing recovery emails (defaults to a JWT_SECRET derivation):
EMAIL_HASH_KEY=""
# Base URL used to build recovery links in emails:
APP_URL="http://localhost:3000"
